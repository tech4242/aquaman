{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": ".",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "composite": true,
    "tsBuildInfoFile": "./tsconfig.tsbuildinfo"
  },
  "include": ["index.ts", "src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "test",
    "src/plugin.ts",
    "src/index.ts",
    "src/commands.ts"
  ],
  "references": [
    { "path": "../proxy" }
  ]
}
