{
  "name": "aquaman-plugin",
  "version": "0.14.0",
  "description": "Protect API keys and secrets for OpenClaw. Credentials stay in your vault, never in the agent's memory",
  "type": "module",
  "scripts": {
    "build": "tsc -b && cp secrets-resolver.mjs dist/secrets-resolver.mjs",
    "prepublishOnly": "npm run clean && npm run build",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.5.7",
      "minGatewayVersion": "2026.5.7"
    },
    "build": {
      "openclawVersion": "2026.6.10",
      "pluginSdkVersion": "2026.6.10"
    }
  },
  "keywords": [
    "aquaman",
    "openclaw",
    "openclaw-plugin",
    "plugin",
    "security",
    "credentials",
    "vault",
    "1password",
    "api-key",
    "secrets",
    "keychain",
    "bitwarden",
    "credential-isolation",
    "token-security",
    "api-protection"
  ],
  "author": "tech4242",
  "license": "MIT",
  "dependencies": {
    "@sinclair/typebox": "^0.34.52",
    "aquaman-proxy": "0.14.0",
    "undici": "^7.25.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.5.7"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "LICENSE",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/tech4242/aquaman.git",
    "directory": "packages/plugin"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "homepage": "https://github.com/tech4242/aquaman/tree/main/packages/plugin#readme",
  "bugs": {
    "url": "https://github.com/tech4242/aquaman/issues"
  }
}
