{
  "name": "aquaman-coder",
  "version": "0.12.1",
  "description": "Vault adapter for AI coding agents. Keep API keys, secrets, and .env contents out of your coding agent's memory and transcripts. Supports Claude Code (Codex, OpenCode, Cursor coming soon).",
  "type": "module",
  "bin": {
    "aquaman-coder": "dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "prepublishOnly": "npm run clean && npm run build",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "keywords": [
    "aquaman",
    "aquaman-coder",
    "claude-code",
    "codex",
    "opencode",
    "cursor",
    "credentials",
    "vault",
    "secrets",
    "dotenv",
    "secret-management",
    "credential-isolation",
    "coding-agent",
    "ai-agent",
    "1password",
    "keychain",
    "bitwarden"
  ],
  "author": "tech4242",
  "license": "MIT",
  "dependencies": {
    "aquaman-proxy": "0.12.0",
    "commander": "^11.0.0",
    "yaml": "^2.3.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/tech4242/aquaman.git",
    "directory": "packages/coder"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "homepage": "https://github.com/tech4242/aquaman/tree/main/packages/coder#readme",
  "bugs": {
    "url": "https://github.com/tech4242/aquaman/issues"
  }
}
