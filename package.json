{
  "name": "aquaman",
  "version": "0.11.2",
  "private": true,
  "description": "API key protection for OpenClaw — credentials stay in your vault, never in the agent's memory",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w aquaman-proxy -w aquaman-plugin",
    "build:proxy": "npm run build -w aquaman-proxy",
    "build:plugin": "npm run build -w aquaman-plugin",
    "clean": "npm run clean --workspaces && rm -rf dist packages/*/tsconfig.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "lint": "oxlint src test packages --ignore-pattern node_modules --ignore-pattern dist --ignore-pattern coverage",
    "lint:fix": "oxlint src test packages --ignore-pattern node_modules --ignore-pattern dist --ignore-pattern coverage --fix",
    "typecheck": "tsc -b packages/proxy packages/plugin",
    "start": "node packages/proxy/dist/cli/index.js",
    "dev": "tsx watch packages/proxy/src/cli/index.ts",
    "docker:build": "docker build -t aquaman -f docker/Dockerfile docker/",
    "docker:run": "docker run --rm -it aquaman"
  },
  "keywords": [
    "aquaman",
    "openclaw",
    "security",
    "credentials",
    "vault",
    "1password",
    "api-key",
    "secrets",
    "keychain",
    "bitwarden",
    "ai-agent",
    "api-protection"
  ],
  "author": "tech4242",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/ws": "^8.5.10",
    "@vitest/coverage-v8": "^1.2.0",
    "ajv": "^8.17.0",
    "openclaw": "^2026.4.9",
    "oxlint": "^0.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
